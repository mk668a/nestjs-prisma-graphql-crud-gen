generator client {
  provider = "prisma-client-js"
}

generator custom_generator {
  provider = "node ../packages/generator/dist-cjs"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

model Users {
  id          String  @id @default(cuid())
  first_name  String  @db.VarChar(255)
  last_name   String  @db.VarChar(255)
  email       String  @unique
  gender      String? @db.VarChar(255)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  posts       Post[]
  role        UserRole
}

enum UserRole {
  ADMIN
  AUTHOR
}

model Post {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  published Boolean
  title     String
  content   String?
  author    Users?    @relation(fields: [authorId], references: [id])
  authorId  String?
}

enum NotificationType {
  newPosts
  newComments
  newFollowers
  reply
  heartOnPost
  heartOnComment
  heartOnReply
}

enum Language {
  Typescript
  Javascript
  Rust
  Go
  Python
  Cpp
}

// --- Repro models for issue #142 (silent failures on complex schemas) ---

// Self-relation
model Category {
  id        String     @id @default(cuid())
  name      String
  parentId  String?
  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryHierarchy")
}

// Composite primary key
model Membership {
  userId    String
  groupId   String
  role      String   @default("member")
  joinedAt  DateTime @default(now())
  group     Group    @relation(fields: [groupId], references: [id])

  @@id([userId, groupId])
  @@index([groupId])
}

model Group {
  id          String       @id @default(cuid())
  name        String
  memberships Membership[]
  tags        Tag[]
}

// Implicit many-to-many
model Tag {
  id     String  @id @default(cuid())
  label  String  @unique
  groups Group[]
}

// Multiple relations between the same two models
model Conversation {
  id          String   @id @default(cuid())
  initiatorId String
  responderId String
  initiator   Account  @relation("InitiatedConversations", fields: [initiatorId], references: [id])
  responder   Account  @relation("RespondedConversations", fields: [responderId], references: [id])
  createdAt   DateTime @default(now())
}

model Account {
  id                      String         @id @default(cuid())
  handle                  String         @unique
  initiatedConversations  Conversation[] @relation("InitiatedConversations")
  respondedConversations  Conversation[] @relation("RespondedConversations")
}
